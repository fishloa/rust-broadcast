{
    "schemaVersion": "1.5.0",
    "acapPackageConf": {
        "setup": {
            "appName": "acapmultimux",
            "vendor": "rust-broadcast",
            "runMode": "respawn",
            "version": "0.1.0"
        },
        "configuration": {
            "reverseProxy": [
                {
                    "apiPath": "hls",
                    "target": "http://localhost:2999",
                    "access": "viewer"
                },
                {
                    "apiPath": "admin",
                    "target": "http://localhost:2999",
                    "access": "admin"
                }
            ],
            "settingPage": "index.html"
        }
    }
}

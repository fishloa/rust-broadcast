target/
**/*.rs.bk
.DS_Store
# Non-redistributable vendored spec PDFs + test media live in the PRIVATE git
# submodule `private/` (repo: rust-broadcast-private) — `private/specs/*.pdf`,
# `private/fixtures/…`. Never manually copied into the public tree. The public
# `specs/` dir keeps only freely-redistributable text specs (RFCs, etc.) +
# manifests; extracted-syntax markdown stays public in each crate's docs/.
# Guard against accidentally dropping a PDF straight into public specs/:
specs/*.pdf
tools/dvb-si-audit/.venv/
tools/dvb-si-audit/out/
.worktree/
.worktrees/
.delegate/
.worktrees/

# stray cross-compile artifacts (never commit)
*.rlib
*.rmeta

# fetch-on-demand broadcast captures (tools/fetch-test-streams.sh) — never committed
/.test-streams/

# wasm-pack build output for the browser demo (generated; not committed)
/demo/pkg/
/demo/target/
.playwright-mcp/
# all scratch cargo target dirs (target/, target-gate/, target-ci/, target-rel/, …)
/target*/
target-*/

# multimux LL-DASH dash.js headless-validation harness (issue #721,
# multimux/tests/lldash_dashjs.rs / multimux/tests/assets/) -- installed JS
# deps only; the pinned dash.all.min.js fixture itself IS committed.
/multimux/tests/assets/node_modules/
